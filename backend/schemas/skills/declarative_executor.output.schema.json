{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeclarativeExecutorOutput",
  "type": "object",
  "required": [
    "skill_name",
    "metadata"
  ],
  "properties": {
    "skill_name": {
      "type": "string"
    },
    "llm_response": {
      "type": [
        "object",
        "null"
      ]
    },
    "script_result": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "success": {
          "type": "boolean"
        },
        "returncode": {
          "type": "integer"
        },
        "output": {},
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "description",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

