{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillRunResponse",
  "type": "object",
  "required": [
    "success",
    "data",
    "records",
    "run_id"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    },
    "data": {
      "type": "array"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chunk_id",
          "status",
          "data"
        ],
        "properties": {
          "chunk_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failed",
              "skipped"
            ]
          },
          "record_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "data": {
            "type": "object"
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object"
    },
    "script_result": {
      "type": "object"
    },
    "run_id": {
      "type": "string"
    },
    "source_hash": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}

