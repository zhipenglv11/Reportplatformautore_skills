{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "overall_status": {
      "type": "string",
      "enum": ["pass", "fail", "needs_review"],
      "description": "文档整体核查结论"
    },
    "summary": {
      "type": "string",
      "description": "简短的核查总结文本"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue_type": {
            "type": "string",
            "enum": [
              "overpaint", 
              "no_strikeout", 
              "missing_signature", 
              "missing_date", 
              "signature_too_far", 
              "unclear"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["major", "minor", "warning"]
          },
          "page": {
            "type": "integer",
            "description": "所在页码"
          },
          "region": {
            "type": "string",
            "description": "问题区域描述 (如: 'Row 5, Col 2' 或 bbox坐标)"
          },
          "evidence_text": {
            "type": "string",
            "description": "识别到的相关文字 (如: '原始值: 15.2, 修改值: 15.3')"
          },
          "reason_short": {
            "type": "string",
            "description": "判定理由简述"
          },
          "fix_suggestion": {
            "type": "string",
            "description": "整改建议"
          }
        },
        "required": ["issue_type", "severity", "page", "fix_suggestion"]
      }
    }
  },
  "required": ["overall_status", "issues"]
}
